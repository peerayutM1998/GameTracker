<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameTracker.Views.HomeView"
             xmlns:models="clr-namespace:GameTracker.Models"
             xmlns:viewmodels="clr-namespace:GameTracker.ViewModels"
             x:DataType="viewmodels:HomeViewModel"
             Title="Game Tracker"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFFFFF">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,10,0,10">
                <Label Text="Game💧Tracker" FontSize="26" FontAttributes="Bold" TextColor="#3A3A4D" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Border Stroke="#F0F0F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F9F9FB" Padding="15,12">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,3" Opacity="0.05" Radius="5"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToSearchCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="ค้นหาเกมถัดไปของคุณ..." TextColor="#A0A0B3" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="🔍" FontSize="20" VerticalOptions="Center" TextColor="#7A75FF" Margin="5,0,0,0"/>
                </Grid>
            </Border>

            <Label Text="Now playing" FontSize="22" FontAttributes="Bold" TextColor="#3A3A4D"/>
            <CollectionView ItemsSource="{Binding NowPlayingGames}" HeightRequest="210">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Game">
                        <Border WidthRequest="160" BackgroundColor="White" StrokeShape="RoundRectangle 15" Stroke="Transparent" Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Opacity="0.1" Radius="8"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=SelectGameCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="*, Auto">
                                <Border Grid.Row="0" StrokeShape="RoundRectangle 15,15,0,0" Stroke="Transparent">
                                    <Image Source="{Binding BackgroundImage}" Aspect="AspectFill" />
                                </Border>

                                <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="3">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#333" FontSize="14" LineBreakMode="TailTruncation" MaxLines="1"/>
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="⭐" TextColor="#FFD700" FontSize="12" VerticalOptions="Center"/>
                                        <Label Text="{Binding Rating}" TextColor="#777" FontSize="12" VerticalOptions="Center"/>
                                        <Label Text="({Binding Progress}%)" TextColor="#7A75FF" FontSize="10" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Recently Added" FontSize="18" FontAttributes="Bold" TextColor="#3A3A4D" Margin="0,10,0,-5"/>
            <CollectionView ItemsSource="{Binding RecentlyAddedGames}" HeightRequest="130">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Game">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" StrokeThickness="1" WidthRequest="130" Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=SelectGameCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto">
                                <Border Grid.Row="0" StrokeShape="RoundRectangle 12,12,0,0" Stroke="Transparent">
                                    <Image Source="{Binding BackgroundImage}" Aspect="AspectFill" />
                                </Border>
                                <Label Grid.Row="1" Text="{Binding Name}" FontAttributes="Bold" TextColor="#333" FontSize="12" Padding="8" LineBreakMode="TailTruncation" MaxLines="1"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>