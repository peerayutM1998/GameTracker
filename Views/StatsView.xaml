<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameTracker.Views.StatsView"
             Title="My Stats"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D1B2A">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="สรุปสถิติการเล่นเกม" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,0,0,20" />

            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="15" ColumnSpacing="15">

                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#1B263B" StrokeShape="RoundRectangle 15" Stroke="Transparent" Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="🎮" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Total Games" TextColor="LightGray" FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="{Binding TotalGames}" TextColor="White" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#1B263B" StrokeShape="RoundRectangle 15" Stroke="Transparent" Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="🔥" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Playing" TextColor="LightGray" FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="{Binding PlayingGames}" TextColor="#FFA500" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#1B263B" StrokeShape="RoundRectangle 15" Stroke="Transparent" Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="✅" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Completed" TextColor="LightGray" FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="{Binding CompletedGames}" TextColor="#00FF7F" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#1B263B" StrokeShape="RoundRectangle 15" Stroke="Transparent" Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="⭐" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Avg Rating" TextColor="LightGray" FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="{Binding AverageRating}" TextColor="#FFD700" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>